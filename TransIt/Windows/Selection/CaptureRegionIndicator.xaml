<Window x:Class="TransIt.Windows.Selection.CaptureRegionIndicator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Border BorderThickness="2" CornerRadius="2">
        <Border.BorderBrush>
            <SolidColorBrush Color="#2196F3"/>
        </Border.BorderBrush>
        <Border.Background>
            <SolidColorBrush Color="#0A2196F3"/>
        </Border.Background>
    </Border>
</Window>
