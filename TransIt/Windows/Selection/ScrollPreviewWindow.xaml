<Window x:Class="TransIt.Windows.Selection.ScrollPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="210"
        Height="320"
        ResizeMode="NoResize">
    <Border Background="#DD1A1A1A" CornerRadius="8" BorderBrush="#444" BorderThickness="1">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="CountLabel"
                       Grid.Row="0"
                       Text="0 images"
                       Foreground="#888" FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,5"/>

            <Border Grid.Row="1" Background="#111" CornerRadius="4" ClipToBounds="True">
                <ScrollViewer x:Name="Scroller"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
