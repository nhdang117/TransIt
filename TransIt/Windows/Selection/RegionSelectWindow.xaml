<Window x:Class="TransIt.Windows.Selection.RegionSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="None"
        Title="Select Region"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        KeyDown="Window_KeyDown">
    <Canvas x:Name="SelectionCanvas">
        <Path x:Name="DimMask"
              Fill="#80000000"
              IsHitTestVisible="False">
            <Path.Data>
                <GeometryGroup FillRule="EvenOdd">
                    <RectangleGeometry x:Name="DimOuterGeometry" />
                    <RectangleGeometry x:Name="DimHoleGeometry" />
                </GeometryGroup>
            </Path.Data>
        </Path>
        <Rectangle x:Name="SelectionRect"
                   Stroke="#0078D7"
                   StrokeThickness="2"
                   Fill="Transparent"
                   Visibility="Collapsed" />
        <Line x:Name="CrosshairVOuter" Stroke="Black" StrokeThickness="1.5" IsHitTestVisible="False" />
        <Line x:Name="CrosshairVInner" Stroke="White" StrokeThickness="0.5" IsHitTestVisible="False" />
        <Line x:Name="CrosshairHOuter" Stroke="Black" StrokeThickness="1.5" IsHitTestVisible="False" />
        <Line x:Name="CrosshairHInner" Stroke="White" StrokeThickness="0.5" IsHitTestVisible="False" />
        <TextBlock x:Name="SizeLabel"
                   Foreground="White"
                   FontSize="12"
                   Background="#80000000"
                   Padding="4,2" />
        <TextBlock Canvas.Left="10" Canvas.Top="10"
                   Foreground="#CCFFFFFF"
                   FontSize="14"
                   Text="Drag to select region • Esc to cancel" />
    </Canvas>
</Window>
