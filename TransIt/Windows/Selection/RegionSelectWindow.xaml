<Window x:Class="TransIt.Windows.Selection.RegionSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        Title="Select Region"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        KeyDown="Window_KeyDown">
    <Canvas x:Name="SelectionCanvas">
        <Rectangle x:Name="SelectionRect"
                   Stroke="White"
                   StrokeThickness="2"
                   Fill="#30FFFFFF"
                   Visibility="Collapsed" />
        <TextBlock x:Name="SizeLabel"
                   Foreground="White"
                   FontSize="12"
                   Background="#80000000"
                   Padding="4,2" />
        <TextBlock Canvas.Left="10" Canvas.Top="10"
                   Foreground="#CCFFFFFF"
                   FontSize="14"
                   Text="Drag to select region • Esc to cancel" />
    </Canvas>
</Window>
