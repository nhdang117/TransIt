<Window x:Class="TransIt.Windows.Selection.WindowPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="OnKeyDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp">
    <Canvas x:Name="OverlayCanvas">

        <!-- Highlight box around hovered window -->
        <Rectangle x:Name="HighlightRect"
                   Fill="#1A2196F3"
                   Stroke="#2196F3" StrokeThickness="2"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>

        <!-- Manual drag rectangle -->
        <Rectangle x:Name="DragRect"
                   Fill="#1A4CAF50"
                   Stroke="#4CAF50" StrokeThickness="2"
                   StrokeDashArray="6 3"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>

        <!-- Hover highlight for detected layout regions -->
        <Rectangle x:Name="LayoutHighlightRect"
                   Fill="#2200C853"
                   Stroke="#00C853" StrokeThickness="2"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>

        <!-- Instruction label — bottom-center -->
        <Border x:Name="HintBorder"
                Canvas.Bottom="0"
                Background="#CC1E1E1E"
                CornerRadius="6"
                Padding="14,6"
                IsHitTestVisible="False">
            <TextBlock Text="Hover a layout region or window panel, click to select"
                       Foreground="White" FontSize="13"/>
        </Border>

    </Canvas>
</Window>
