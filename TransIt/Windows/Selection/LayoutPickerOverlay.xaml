<Window x:Class="TransIt.Windows.Selection.LayoutPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="OnKeyDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp">

    <Grid>
        <!-- Frozen screenshot background -->
        <Image x:Name="BackgroundImage" Stretch="Fill" IsHitTestVisible="False"/>

        <!-- Layer 1: layout region borders drawn here programmatically -->
        <Canvas x:Name="RegionsCanvas" IsHitTestVisible="False"/>

        <!-- Layer 2: hover highlight, drag rect, badges -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">

            <!-- Hover / auto-snap highlight -->
            <Rectangle x:Name="HoverRect"
                       Fill="#282196F3"
                       Stroke="#2196F3" StrokeThickness="2"
                       Visibility="Collapsed"/>

            <!-- Manual drag selection -->
            <Rectangle x:Name="DragRect"
                       Fill="#284CAF50"
                       Stroke="#4CAF50" StrokeThickness="2"
                       StrokeDashArray="6 3"
                       Visibility="Collapsed"/>

            <!-- Category badge shown near hover rect -->
            <Border x:Name="CategoryBadge"
                    Background="#CC1565C0"
                    CornerRadius="3"
                    Padding="7,3"
                    Visibility="Collapsed">
                <TextBlock x:Name="CategoryText"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Bottom-center hint -->
            <Border x:Name="HintBorder"
                    Background="#CC1E1E1E"
                    CornerRadius="6"
                    Padding="14,6">
                <TextBlock Text="Hover to auto-select region  ·  Drag for manual selection  ·  Esc to cancel"
                           Foreground="White"
                           FontSize="13"/>
            </Border>

        </Canvas>
    </Grid>
</Window>
