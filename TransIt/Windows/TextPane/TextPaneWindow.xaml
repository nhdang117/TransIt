<Window x:Class="TransIt.Windows.TextPane.TextPaneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Width="440" SizeToContent="Height" MaxHeight="580"
        Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border Background="#E61E1E1E" CornerRadius="10"
            BorderBrush="#40FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Drag header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll"
                  Margin="14,12,14,8">
                <TextBlock Text="TransIt" Foreground="#888888" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right"
                        Click="BtnClose_Click"
                        Background="Transparent" Foreground="#888888"
                        BorderThickness="0" FontSize="13" Padding="6,0"
                        Cursor="Arrow"/>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Row="1" Height="1" Fill="#30FFFFFF" Margin="14,0,14,0"/>

            <!-- Content -->
            <ScrollViewer Grid.Row="2" MaxHeight="520"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,0">
                <StackPanel Margin="14,12,14,14">

                    <!-- Loading state -->
                    <StackPanel x:Name="LoadingPanel" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,16,0,16">
                        <TextBlock Text="Translating…" Foreground="#AAAAAA"
                                   FontSize="13" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Results -->
                    <StackPanel x:Name="ResultsPanel" Visibility="Collapsed"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
