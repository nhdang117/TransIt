<Window x:Class="TransIt.Windows.Chat.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Width="500" Height="640"
        MinWidth="380" MinHeight="400"
        Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Border Background="#E61E1E1E" CornerRadius="10"
            BorderBrush="#40FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Drag header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll"
                  Margin="14,12,14,8">
                <TextBlock Text="TransIt — Chat" Foreground="#888888" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right"
                        Click="BtnClose_Click"
                        Background="Transparent" Foreground="#888888"
                        BorderThickness="0" FontSize="13" Padding="6,0"
                        Cursor="Arrow"/>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Row="1" Height="1" Fill="#30FFFFFF" Margin="14,0,14,0"/>

            <!-- Chat area -->
            <Grid Grid.Row="2">
                <ScrollViewer x:Name="ChatScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ChatPanel" Margin="12,10,12,10"/>
                </ScrollViewer>

                <!-- Loading overlay -->
                <Border x:Name="LoadingPanel" Background="#E61E1E1E"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Đang phân tích…" Foreground="#AAAAAA"
                                   FontSize="13" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Divider above input -->
            <Rectangle Grid.Row="3" Height="1" Fill="#30FFFFFF" Margin="14,0,14,0"/>

            <!-- Input row -->
            <Grid x:Name="InputRow" Grid.Row="4" Margin="12,8,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Grid.Column="0"
                         Background="#2A2A2A" Foreground="White"
                         CaretBrush="White"
                         BorderBrush="#40FFFFFF" BorderThickness="1"
                         Padding="10,8" FontSize="13" FontFamily="Segoe UI"
                         TextWrapping="Wrap" AcceptsReturn="False"
                         MaxLines="1"
                         VerticalContentAlignment="Center"
                         KeyDown="InputBox_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="Hỏi về nội dung…" Foreground="#555555"
                                                   FontFamily="Segoe UI" FontSize="13" Margin="10,0,0,0"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button x:Name="SendBtn" Grid.Column="1"
                        Content="Gửi" Click="SendBtn_Click"
                        Background="#2563EB" Foreground="White"
                        BorderThickness="0" FontSize="13" FontFamily="Segoe UI"
                        Padding="14,8" Margin="8,0,0,0"
                        Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>
