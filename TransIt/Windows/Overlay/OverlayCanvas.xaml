<UserControl x:Class="TransIt.Windows.Overlay.OverlayCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <!-- Layer 0: frozen screenshot background -->
        <Image x:Name="FrozenLayer" Stretch="Fill" Visibility="Collapsed" />

        <!-- Layer 1: translated text blocks -->
        <Canvas x:Name="TextLayer" />

        <!-- Layer 1b: OCR debug rectangles (Ctrl+1 test mode) -->
        <Canvas x:Name="DebugLayer" />

        <!-- Layer 2: ink annotations -->
        <InkCanvas x:Name="InkLayer"
                   Background="Transparent"
                   IsHitTestVisible="False" />

        <!-- Layer 3: loading indicator -->
        <Grid x:Name="LoadingLayer" Visibility="Collapsed"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Background="#CC1E1E1E" CornerRadius="12" Padding="28,20">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="44" Height="44" HorizontalAlignment="Center">
                        <!-- Dim track ring -->
                        <Ellipse Width="44" Height="44" Stroke="#40FFFFFF" StrokeThickness="3"/>
                        <!-- 270° spinning arc, rounded caps -->
                        <Path Stroke="White" StrokeThickness="3"
                              StrokeEndLineCap="Round" StrokeStartLineCap="Round">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="22,2">
                                        <ArcSegment Point="2,22" Size="20,20"
                                                    SweepDirection="Clockwise"
                                                    IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" CenterX="22" CenterY="22"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>
                    <TextBlock Text="Translating…" Foreground="White" FontSize="13"
                               FontFamily="Segoe UI" Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Layer 4: annotation toolbar -->
        <Border x:Name="Toolbar"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,16,0,0"
                Background="#CC1E1E1E"
                CornerRadius="8"
                Padding="8,4"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" >
                <Button Content="+" Click="BtnAddRegion_Click" Margin="4,0" Padding="8,4" FontWeight="Bold" FontSize="14" />
                <Button Content="✏ Pen"    Click="BtnPen_Click"    Margin="4,0" Padding="8,4" />
                <Button Content="⬤ Color"  Click="BtnColor_Click"  Margin="4,0" Padding="8,4" />
                <Button Content="✕ Erase"  Click="BtnErase_Click"  Margin="4,0" Padding="8,4" />
                <Button Content="📷 Export" Click="BtnExport_Click" Margin="4,0" Padding="8,4" />
                <Button Content="✂ Copy"   Click="BtnCopy_Click"   Margin="4,0" Padding="8,4" />
                <Button Content="✖ Close"  Click="BtnClose_Click"  Margin="4,0" Padding="8,4"
                        Foreground="#FF4444" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
